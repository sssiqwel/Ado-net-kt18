@implements IDisposable
@using System.Globalization

<div class="sales-chart-card">
    <h3>Динамика продаж (последние 12 месяцев)</h3>
    <p class="chart-caption">Значения обновляются каждые 2 секунды для имитации поступающих данных.</p>

    <svg viewBox="0 0 800 360" role="img" aria-label="График продаж">
        <defs>
            <linearGradient id="sales-area-gradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#2b7fff" stop-opacity="0.22" />
                <stop offset="100%" stop-color="#2b7fff" stop-opacity="0.02" />
            </linearGradient>
        </defs>

        <line x1="@Inv(ChartLeft)" y1="@Inv(ChartTop)" x2="@Inv(ChartLeft)" y2="@Inv(ChartBottom)" class="axis" />
        <line x1="@Inv(ChartLeft)" y1="@Inv(ChartBottom)" x2="@Inv(ChartRight)" y2="@Inv(ChartBottom)" class="axis" />

        @foreach (var yTick in GetYTicks())
        {
            <line x1="@Inv(ChartLeft)" y1="@Inv(yTick.Y)" x2="@Inv(ChartRight)" y2="@Inv(yTick.Y)" class="grid" />
            <foreignObject x="4" y="@Inv(yTick.Y - 10)" width="70" height="20">
                <div xmlns="http://www.w3.org/1999/xhtml" class="axis-label-y">@($"{yTick.Value}k")</div>
            </foreignObject>
        }

        <polygon points="@GetAreaPolygonPoints()" class="sales-area" fill="url(#sales-area-gradient)" />
        <polyline points="@GetPolylinePoints()" class="sales-line" />

        @foreach (var point in GetPointsWithCoordinates())
        {
            <circle cx="@Inv(point.X)" cy="@Inv(point.Y)" r="5" class="sales-dot" />
            <line x1="@Inv(point.X)" y1="@Inv(ChartBottom)" x2="@Inv(point.X)" y2="@Inv(ChartBottom + 6)" class="axis-tick" />
            <foreignObject x="@Inv(point.X - 28)" y="298" width="56" height="52">
                <div xmlns="http://www.w3.org/1999/xhtml" class="axis-label-x">@point.Month</div>
            </foreignObject>
        }

        <foreignObject x="4" y="8" width="72" height="22">
            <div xmlns="http://www.w3.org/1999/xhtml" class="axis-title-y">тыс. ед.</div>
        </foreignObject>
    </svg>

    <div class="totals">
        <span>Текущий месяц: <strong>@($"{_sales[^1].Value}k")</strong></span>
        <span>Среднее: <strong>@($"{_sales.Average(x => x.Value):0.0}k")</strong></span>
    </div>
</div>

@code {
    private const double ChartLeft = 88;
    private const double ChartTop = 36;
    private const double ChartRight = 760;
    private const double ChartBottom = 286;
    private const int MaxValue = 220;

    private readonly Random _random = new();
    private readonly List<SalesPoint> _sales = new();
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        SeedSales();
        StartUpdates();
    }

    private void SeedSales()
    {
        var months = new[] { "Янв", "Фев", "Мар", "Апр", "Май", "Июн", "Июл", "Авг", "Сен", "Окт", "Ноя", "Дек" };

        _sales.Clear();
        foreach (var month in months)
        {
            _sales.Add(new SalesPoint(month, _random.Next(60, 180)));
        }
    }

    private void StartUpdates()
    {
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));

        _ = Task.Run(async () =>
        {
            while (_timer is not null && await _timer.WaitForNextTickAsync(_cts.Token))
            {
                UpdateLatestSalesPoint();
                await InvokeAsync(StateHasChanged);
            }
        }, _cts.Token);
    }

    private void UpdateLatestSalesPoint()
    {
        var latest = _sales[^1].Value;
        var next = Math.Clamp(latest + _random.Next(-12, 14), 40, MaxValue);
        _sales[^1] = _sales[^1] with { Value = next };
    }

    private IEnumerable<(int Value, double Y)> GetYTicks()
    {
        for (var value = 0; value <= MaxValue; value += 40)
        {
            yield return (value, GetY(value));
        }
    }

    private IEnumerable<(string Month, double X, double Y)> GetPointsWithCoordinates()
    {
        var step = (ChartRight - ChartLeft) / (_sales.Count - 1);
        for (var i = 0; i < _sales.Count; i++)
        {
            yield return (_sales[i].Month, ChartLeft + i * step, GetY(_sales[i].Value));
        }
    }

    private string GetPolylinePoints()
    {
        return string.Join(" ", GetPointsWithCoordinates().Select(p => $"{Inv(p.X)},{Inv(p.Y)}"));
    }

    private string GetAreaPolygonPoints()
    {
        var pts = GetPointsWithCoordinates().ToList();
        if (pts.Count == 0)
        {
            return string.Empty;
        }

        var top = string.Join(" ", pts.Select(p => $"{Inv(p.X)},{Inv(p.Y)}"));
        return $"{Inv(ChartLeft)},{Inv(ChartBottom)} {top} {Inv(ChartRight)},{Inv(ChartBottom)}";
    }

    /// <summary>SVG требует точку как разделитель дроби; при ru-RU иначе ломается разбор points.</summary>
    private static string Inv(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private static double GetY(int value)
    {
        return ChartBottom - (value / (double)MaxValue) * (ChartBottom - ChartTop);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _timer?.Dispose();
        _cts?.Dispose();
    }

    private sealed record SalesPoint(string Month, int Value);
}
